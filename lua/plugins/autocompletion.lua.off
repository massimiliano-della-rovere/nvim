  -- ============================================================
  -- zbirenbaum/copilot.lua  --  VERSIONE PRINCIPALE
  -- ============================================================
  -- Rewrite Lua puro di github/copilot.vim con:
  --   • ghost text inline (suggestion.enabled = true)
  --   • NES - Next Edit Suggestions: Copilot suggerisce la
  --     PROSSIMA modifica nel file, non solo al cursore.
  --     Abilitato via server_opts_overrides.
  --
  -- NOTE DEPRECAZIONI (upstream, non nel nostro codice):
  --   • client.is_stopped  →  sarà rimosso in 0.13.
  --     Traceback in copilot.lua/client/init.lua e copilot-cmp.
  --     Fix in attesa upstream:
  --       https://github.com/zbirenbaum/copilot.lua/issues
  --       https://github.com/zbirenbaum/copilot-cmp/issues
  --   • vim.validate{<table>}  →  rimosso in Nvim 1.0.
  --     Traceback in cmp-async-path/init.lua.
  --     Non impatta il funzionamento; attesa fix upstream.
  --
  -- PRIMA AUTENTICAZIONE: :Copilot auth
  --
  -- TASTI (insert mode):
  --   <C-J>        accetta l'intero suggerimento
  --   <M-Right>    accetta la prossima parola
  --   <M-C-Right>  accetta la prossima riga
  --   <C-]>        scarta il suggerimento
  --   <M-]>        suggerimento successivo
  --   <M-[>        suggerimento precedente
  --   <M-\\>        richiedi esplicitamente un suggerimento
  -- ============================================================
  {
    "zbirenbaum/copilot.lua",
    cmd   = "Copilot",
    event = "InsertEnter",
    config = function()
      require("copilot").setup({
        -- ── Ghost text inline ─────────────────────────────
        -- suggestion.enabled = true: i suggerimenti appaiono
        -- come ghost text inline (non nel menu cmp).
        suggestion = {
          enabled          = true,
          auto_trigger     = true,
          hide_during_completion = true,
          debounce         = 75,
          -- I keymaps sono impostati manualmente sotto
          -- per coerenza con il resto della configurazione.
          keymap = {
            accept        = false,
            accept_word   = false,
            accept_line   = false,
            next          = false,
            prev          = false,
            dismiss       = false,
          },
        },

        -- Panel disabilitato: usiamo il ghost text inline.
        panel = { enabled = false },

        -- ── NES: Next Edit Suggestions ─────────────────────
        -- Copilot suggerisce la prossima modifica logica
        -- nel file, non solo il completamento al cursore.
        -- Richiede Language Server >= 1.342.
        server_opts_overrides = {
          settings = {
            advanced = {
              nextEditSuggestions = {
                enabled = true,
              },
            },
          },
        },

        -- ── Filetypes ─────────────────────────────────────
        filetypes = {
          python          = true,
          lua             = true,
          typescript      = true,
          javascript      = true,
          TelescopePrompt = false,
          ["dap-repl"]    = false,
          gitcommit       = false,
          gitrebase       = false,
          help            = false,
          text            = false,
        },
      })

      -- ── Keymaps usando l'API Lua di copilot.lua ─────────
      -- A differenza di copilot.vim (che usa <Plug> di Vimscript),
      -- copilot.lua espone moduli Lua direttamente.
      local sug = require("copilot.suggestion")

      vim.keymap.set("i", "<C-J>",
        function() sug.accept() end,
        { silent = true, desc = "Copilot: accept" })
      vim.keymap.set("i", "<M-Right>",
        function() sug.accept_word() end,
        { silent = true, desc = "Copilot: accept word" })
      vim.keymap.set("i", "<M-C-Right>",
        function() sug.accept_line() end,
        { silent = true, desc = "Copilot: accept line" })
      vim.keymap.set("i", "<C-]>",
        function() sug.dismiss() end,
        { silent = true, desc = "Copilot: dismiss" })
      vim.keymap.set("i", "<M-]>",
        function() sug.next() end,
        { silent = true, desc = "Copilot: next suggestion" })
      vim.keymap.set("i", "<M-[>",
        function() sug.prev() end,
        { silent = true, desc = "Copilot: prev suggestion" })
      vim.keymap.set("i", "<M-\\>",
        function()
          if sug.is_visible() then sug.dismiss()
          else vim.cmd("Copilot suggestion") end
        end,
        { silent = true, desc = "Copilot: toggle suggestion" })

      -- Highlight ghost text
      vim.api.nvim_create_autocmd("ColorScheme", {
        group    = vim.api.nvim_create_augroup("CopilotHL", { clear = true }),
        callback = function()
          vim.api.nvim_set_hl(0, "CopilotSuggestion",
            { fg = "#6e6e6e", ctermfg = 8, italic = true, force = true })
        end,
      })
    end,
  },


  -- ============================================================
  -- CopilotC-Nvim/CopilotChat.nvim  --  AI chat in Neovim
  -- ============================================================
  -- Chat con GitHub Copilot direttamente in Neovim, con contesto
  -- del buffer/selezione corrente, diagnostics LSP e storia.
  --
  -- KEYMAPS  (<leader>a):
  --   <leader>aa   apri chat (buffer completo come contesto)
  --   <leader>as   chat con selezione visuale
  --   <leader>aq   domanda rapida (vim.ui.input)
  --   <leader>ap   prompt actions (via Telescope)
  --   <leader>ax   chiudi chat
  --   <leader>ar   reset chat
  -- ============================================================
  {
    "CopilotC-Nvim/CopilotChat.nvim",
    branch       = "main",
    dependencies = {
      "zbirenbaum/copilot.lua",   -- ora il backend principale
      "nvim-lua/plenary.nvim",
    },
    event = "VeryLazy",
    config = function()
      local chat = require("CopilotChat")

      chat.setup({
        debug   = false,
        model   = "gpt-4o",
        temperature = 0.1,
        system_prompt = require("CopilotChat.prompts").COPILOT_INSTRUCTIONS,

        window = {
          layout   = "vertical",
          width    = 0.40,
          height   = 0.50,
          border   = "single",
          title    = " Copilot Chat ",
          zindex   = 50,
        },

        mappings = {
          complete        = { insert = "<Tab>" },
          close           = { normal = "q",    insert = "<C-c>" },
          reset           = { normal = "<M-r>", insert = "<M-r>" },
          submit_prompt   = { normal = "<CR>",  insert = "<M-CR>" },
          accept_diff     = { normal = "<M-a>", insert = "<M-a>" },
          show_diff       = { normal = "<M-d>" },
          show_system_prompt = { normal = "<M-s>" },
          show_user_selection = { normal = "<M-u>" },
        },

        -- Sorgenti di contesto predefinite
        context  = "buffer",     -- invia il buffer corrente come contesto
        history_path = vim.fn.stdpath("data") .. "/copilot_chat_history.json",
        auto_follow_cursor = true,
        auto_insert_mode   = false,
        insert_at_end      = false,
        clear_chat_on_new_prompt = false,
        highlight_selection = true,
      })

      -- ── Integrazione con nvim-cmp ─────────────────────────
      -- CopilotChat usa vim.fn.complete() per / e @ nel buffer
      -- di chat. Registriamo il source cmp (se la versione lo
      -- espone) e configuriamo il filetype "copilot-chat" per
      -- avere un menu cmp completo nel buffer di chat.
      --
      -- Risultato:
      --   /        → menu cmp con slash commands (stile dropdown)
      --   @        → menu cmp con agents disponibili
      --   <leader>cp → action palette via Telescope (gia' configurato)
      --   vim.ui.select → Telescope dropdown (via telescope-ui-select)
      local ok_cmp_int, cmp_int = pcall(require, "CopilotChat.integrations.cmp")
      if ok_cmp_int and cmp_int.setup then
        cmp_int.setup()
      end

      -- cmp filetype per il buffer copilot-chat:
      -- usa copilotchat source (se registrata da cmp_int) + buffer
      local ok_cmp, cmp_ft = pcall(require, "cmp")
      if ok_cmp then
        cmp_ft.setup.filetype("copilot-chat", {
          -- Completion nel buffer di chat: fonte principale copilotchat
          -- (comandi / e agenti @), fallback su buffer per parole
          sources = cmp_ft.config.sources(
            { { name = "copilotchat" } },
            { { name = "buffer",      keyword_length = 3 } }
          ),
          -- Frecce su/giu come nel resto della config
          mapping = cmp_ft.mapping.preset.insert({
            ["<Tab>"]   = cmp_ft.mapping.confirm({ behavior = cmp_ft.ConfirmBehavior.Insert, select = true }),
            ["<CR>"]    = cmp_ft.mapping.confirm({ behavior = cmp_ft.ConfirmBehavior.Replace, select = false }),
            ["<C-y>"]   = cmp_ft.mapping.confirm({ behavior = cmp_ft.ConfirmBehavior.Insert, select = true }),
            ["<C-e>"]   = cmp_ft.mapping.abort(),
            ["<C-n>"]   = cmp_ft.mapping.select_next_item({ behavior = cmp_ft.SelectBehavior.Select }),
            ["<C-p>"]   = cmp_ft.mapping.select_prev_item({ behavior = cmp_ft.SelectBehavior.Select }),
            ["<Down>"]  = cmp_ft.mapping.select_next_item({ behavior = cmp_ft.SelectBehavior.Select }),
            ["<Up>"]    = cmp_ft.mapping.select_prev_item({ behavior = cmp_ft.SelectBehavior.Select }),
          }),
        })
      end

      -- Keymaps globali
      vim.keymap.set("n", km.copilot .. "a",
        function() chat.open() end,
        { desc = "CopilotChat: open" })
      vim.keymap.set("v", km.copilot .. "s",
        function() chat.open() end,
        { desc = "CopilotChat: open with selection" })
      vim.keymap.set("n", km.copilot .. "x",
        function() chat.close() end,
        { desc = "CopilotChat: close" })
      vim.keymap.set("n", km.copilot .. "r",
        function() chat.reset() end,
        { desc = "CopilotChat: reset" })
      vim.keymap.set("n", km.copilot .. "q", function()
        vim.ui.input({ prompt = "Copilot Chat: " }, function(input)
          if input and input ~= "" then
            chat.ask(input, {
              selection = require("CopilotChat.select").buffer,
            })
          end
        end)
      end, { desc = "CopilotChat: quick ask" })
      vim.keymap.set({ "n", "v" }, km.copilot .. "p", function()
        local actions = require("CopilotChat.actions")
        require("CopilotChat.integrations.telescope").pick(
          actions.prompt_actions())
      end, { desc = "CopilotChat: prompt actions" })
    end,
  },

  -- ============================================================
  -- olimorris/codecompanion.nvim  --  AI assistant (Claude)
  -- ============================================================
  -- Interfaccia completa per dialogare con Claude (Anthropic) e
  -- altri LLM direttamente in Neovim. Distinto da CopilotChat:
  --
  --   CopilotChat     →  usa GitHub Copilot come backend
  --   CodeCompanion   →  usa ANTHROPIC_API_KEY, parla con Claude
  --
  -- SETUP:
  --   export ANTHROPIC_API_KEY="sk-ant-..."  (nel .bashrc/.zshrc)
  --   Opzionale: ollama serve  (per modelli locali gratuiti)
  --   :checkhealth codecompanion  per verificare dipendenze
  --
  -- PROVIDER CONFIGURATI:
  --   anthropic  →  Claude Opus 4.7 / Sonnet 4.6 (cloud, API key)
  --   ollama     →  qualsiasi modello locale (gratuito, offline)
  --                 es. :CodeCompanionChat ollama
  --
  -- KEYMAPS (<leader>a):
  --   <leader>ac       apri/chiudi chat con Claude
  --   <leader>aI       inline assist (trasforma/crea codice inline)
  --   <leader>aA       action palette (tutte le azioni disponibili)
  --   <leader>aB       aggiungi il buffer corrente al contesto chat
  --
  -- Nel buffer di chat:
  --   /buffer          includi un buffer nel contesto
  --   /file            includi un file dal filesystem
  --   /symbols         includi i simboli (aerial) del buffer
  --   /terminal        includi l ouput del terminale
  --   /help            cerca nella documentazione di Neovim
  --   /doc             genera documentazione per il codice
  --   /now             inserisce data/ora corrente
  --   @full_stack_dev  attiva il ruolo di sviluppatore full-stack
  --   #editor          usa lo strumento editor (modifica file)
  --   #cmd_runner      esegui comandi shell
  --   #files           operazioni sul filesystem
  --   #web_fetch       recupera contenuto da URL (Claude only)
  -- ============================================================
  {
    "olimorris/codecompanion.nvim",
    dependencies = {
      "nvim-lua/plenary.nvim",
      "nvim-treesitter/nvim-treesitter",
      "nvim-telescope/telescope.nvim",    -- per il picker
      { "j-hui/fidget.nvim", opts = {} }, -- progress spinner LSP-style
    },
    event = "VeryLazy",
    config = function()
      require("codecompanion").setup({

        -- ── Adapter: provider LLM ──────────────────────────
        adapters = {
          -- Provider principale: Claude di Anthropic
          -- Richiede ANTHROPIC_API_KEY nell ambiente.
          -- claude-opus-4-7   = piu potente, piu lento
          -- claude-sonnet-4-6 = bilanciato (default)
          -- claude-haiku-4-5  = veloce, economico
          anthropic = function()
            return require("codecompanion.adapters").extend("anthropic", {
              env = { api_key = "ANTHROPIC_API_KEY" },
              schema = {
                model = { default = "claude-opus-4-7" },
              },
            })
          end,

          -- Provider alternativo: Claude Sonnet per risposte rapide
          anthropic_fast = function()
            return require("codecompanion.adapters").extend("anthropic", {
              name   = "anthropic_fast",
              env    = { api_key = "ANTHROPIC_API_KEY" },
              schema = {
                model = { default = "claude-sonnet-4-6" },
              },
            })
          end,

          -- Provider locale (opzionale, gratuito):
          -- Richiede: ollama serve + ollama pull <model>
          -- Modelli consigliati: llama3.2, codestral, qwen2.5-coder
          -- Per attivarlo: :CodeCompanionChat ollama
          ollama = function()
            return require("codecompanion.adapters").extend("ollama", {
              schema = {
                model = { default = "llama3.2" },
                num_ctx = { default = 16384 },
              },
            })
          end,
        },

        -- ── Strategie: quale adapter usa ogni modalita ─────
        strategies = {
          -- Chat: buffer di conversazione libera
          chat = {
            adapter  = "anthropic",
            -- Tasto per inviare il messaggio (oltre a Enter)
            keymaps  = {
              send     = { modes = { n = "<CR>", i = "<C-CR>" } },
              close    = { modes = { n = "q" } },
              stop     = { modes = { n = "<C-c>" } },
              clear    = { modes = { n = "<C-x>" } },
              next_chat = { modes = { n = "}" } },
              prev_chat = { modes = { n = "{" } },
            },
            slash_commands = {
              -- /file: usa telescope per il picker
              ["file"] = {
                opts = { provider = "telescope" },
              },
              -- /buffer: usa telescope
              ["buffer"] = {
                opts = { provider = "telescope" },
              },
              -- /symbols: usa telescope
              ["symbols"] = {
                opts = { provider = "telescope" },
              },
            },
          },

          -- Inline: trasforma/genera codice nel buffer corrente
          inline = {
            adapter = "anthropic_fast",   -- Sonnet: piu veloce per inline
            keymaps = {
              accept_change = { modes = { n = km.ai .. "a" } },
              reject_change = { modes = { n = km.ai .. "r" } },
            },
          },

          -- Agent: orchestratore con tool use
          agent = {
            adapter = "anthropic",
            tools   = {
              opts = {
                auto_submit_errors    = false,
                auto_submit_success   = false,
              },
            },
          },
        },

        -- ── Display ────────────────────────────────────────
        display = {
          -- Buffer di chat: split verticale a destra
          chat = {
            intro_message  = "Ciao! Sono Claude. Come posso aiutarti?",
            show_header_separator = true,
            separator      = "â",   -- ─
            show_token_count = true,            -- mostra token usati
            token_count_display = function(tokens, adapter)
              return " " .. tokens .. " tk [" .. adapter.formatted_name .. "]"
            end,
            start_in_insert_mode = false,
            window = {
              layout  = "vertical",
              width   = 0.40,              -- 40% della larghezza
              height  = 1.0,
              border  = "single",
              relative = "editor",
              position = "right",
            },
          },

          -- Inline: mostra le modifiche come diff evidenziato
          inline = {
            diff = {
              enabled      = true,
              close_chat_at = 240,
              layout       = "vertical",
              opts         = { "internal", "filler", "closeoff" },
            },
          },

          -- Action palette: usa telescope per la selezione
          action_palette = {
            provider = "telescope",
          },
        },

        -- ── Opzioni generali ───────────────────────────────
        opts = {
          log_level = "ERROR",
          -- Usa CLAUDE.md / .cursor/rules se presenti nel progetto
          system_prompt = function(opts)
            return require("codecompanion.config").DEFAULT_SYSTEM_PROMPT(opts)
          end,
        },
      })

      -- ── Keymaps (<leader>a*) ──────────────────────────────
      -- I keymaps CopilotChat usano aa/as/aq/ap/ax/ar;
      -- CodeCompanion usa ac/aI/aA/aB per evitare conflitti.

      -- Chat toggle: apre/chiude la finestra di chat con Claude
      vim.keymap.set({ "n", "v" }, km.ai .. "c",
        "<CMD>CodeCompanionChat Toggle<CR>",
        { desc = "Claude: chat toggle" })

      -- Inline assist: trasforma il codice selezionato (o genera)
      -- Es: seleziona funzione → <leader>aI → scrivi "add docstring"
      vim.keymap.set({ "n", "v" }, km.ai,
        "<CMD>CodeCompanion<CR>",
        { desc = "Claude: inline assist" })

      -- Action palette: lista di tutte le azioni disponibili
      -- Include: explain code, fix diagnostics, unit tests, docs...
      vim.keymap.set({ "n", "v" }, km.ai .. "A",
        "<CMD>CodeCompanionActions<CR>",
        { desc = "Claude: action palette" })

      -- Aggiungi buffer corrente al contesto della chat attiva
      vim.keymap.set("n", km.ai .. "B",
        "<CMD>CodeCompanionChat Add<CR>",
        { desc = "Claude: add buffer to chat" })

      -- ── Integrazione con fidget.nvim ─────────────────────
      -- Mostra lo spinner di progresso nella statusline
      -- mentre Claude elabora la risposta.
      local ok_fidget, fidget = pcall(require, "fidget")
      if ok_fidget then
        local group = vim.api.nvim_create_augroup("CodeCompanionFidget", { clear = true })
        local handle

        vim.api.nvim_create_autocmd("User", {
          group   = group,
          pattern = "CodeCompanionRequestStarted",
          callback = function(args)
            handle = fidget.progress.handle.create({
              title   = " Claude",
              message = "Thinking...",
              lsp_client = { name = args.data and args.data.adapter or "Claude" },
            })
          end,
        })
        vim.api.nvim_create_autocmd("User", {
          group   = group,
          pattern = "CodeCompanionRequestFinished",
          callback = function()
            if handle then
              handle:finish()
              handle = nil
            end
          end,
        })
      end
    end,
  },


}
